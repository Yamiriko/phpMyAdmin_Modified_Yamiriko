{{ login_header|raw }}

{# Load Animate.css + Font Awesome + SweetAlert2 (hanya untuk login page) #}
<link rel="stylesheet" href="js/vendor/animate/animate.min.css">
<link rel="stylesheet" href="js/vendor/fontawesome/css/all.min.css">
<link rel="stylesheet" href="js/vendor/sweetalert2/sweetalert2.min.css">

{% if is_demo %}
  <div class="card mb-4 login-anim-card">
    <div class="card-header">{% trans 'phpMyAdmin Demo Server' %}</div>
    <div class="card-body">
      {% apply format('<a href="url.php?url=https://demo.phpmyadmin.net/" target="_blank" rel="noopener noreferrer">demo.phpmyadmin.net</a>')|raw %}
        {% trans %}
          You are using the demo server. You can do anything here, but please do not change root, debian-sys-maint and pma users. More information is available at %s.
        {% endtrans %}
      {% endapply %}
    </div>
  </div>
{% endif %}

{% if available_languages is not empty %}
  <div class='hide js-show'>
    <div class="card mb-4">
      <div class="card-header">
        <span id="languageSelectLabel">
          {% trans 'Language' %}
          {% if 'Language'|trans != 'Language' %}
            <i lang="en" dir="ltr">(Language)</i>
          {% endif %}
        </span>
      </div>
      <div class="card-body">
        <form method="get" action="{{ url('/') }}" class="disableAjax">
          {{ get_hidden_inputs(form_params) }}
          <select name="lang" class="form-select autosubmit" lang="en" dir="ltr" id="languageSelect" aria-labelledby="languageSelectLabel">
            {% for language in available_languages %}
              <option value="{{ language.getCode()|lower }}"{{ language.isActive() ? ' selected' }}>
                {{- language.getName()|raw -}}
              </option>
            {% endfor %}
          </select>
        </form>
      </div>
    </div>
  </div>
{% endif %}

<form method="post" id="login_form" action="index.php?route=/" name="login_form" class="disableAjax{{ not has_autocomplete ? ' autocomplete="off"' : '' }}">
  {{ get_hidden_inputs(form_params, '', 0, 'server') }}
  <input type="hidden" name="set_session" value="{{ session_id }}">
  {% if is_session_expired %}
    <input type="hidden" name="session_timedout" value="1">
  {% endif %}

  <div class="card mb-4 login-anim-card">
    <div class="card-header">
      <i class="fas fa-sign-in-alt"></i> {% trans 'Log in' %}
      {{ show_docu('index') }}
    </div>
    <div class="card-body">
      {% if is_arbitrary_server_allowed %}
        <div class="row mb-3 login-anim-field" style="--d:0">
          <label for="serverNameInput" class="col-sm-4 col-form-label" title="{% trans 'You can enter hostname/IP address and port separated by space.' %}">
            <i class="fas fa-server"></i> {% trans 'Server:' %}
          </label>
          <div class="col-sm-8">
            <input type="text" name="pma_servername" id="serverNameInput" value="{{ default_server }}" class="form-control" title="
              {%- trans 'You can enter hostname/IP address and port separated by space.' %}">
          </div>
        </div>
      {% endif %}

      <div class="row mb-3 login-anim-field" style="--d:1">
        <label for="input_username" class="col-sm-4 col-form-label">
          <i class="fas fa-user"></i> {% trans 'Username:' %}
        </label>
        <div class="col-sm-8">
          <input type="text" name="pma_username" id="input_username" value="{{ default_user }}" class="form-control" autocomplete="username" spellcheck="false">
        </div>
      </div>

      <div class="row login-anim-field" style="--d:2">
        <label for="input_password" class="col-sm-4 col-form-label">
          <i class="fas fa-lock"></i> {% trans 'Password:' %}
        </label>
        <div class="col-sm-8">
          <input type="password" name="pma_password" id="input_password" value="" class="form-control" autocomplete="current-password" spellcheck="false">
        </div>
      </div>

      <div class="row mt-3 login-anim-field" style="--d:3">
        <div class="col-sm-12">
          <div class="pma-captcha-box">
            <div class="pma-captcha-header">
              <span class="pma-captcha-title"><i class="fas fa-shield-alt"></i> Captcha</span>
              <button type="button" id="btn_refresh_captcha" class="pma-captcha-refresh" title="Ganti CAPTCHA">
                <i class="fas fa-sync-alt"></i> Ganti
              </button>
            </div>
            <p class="pma-captcha-desc">Masukkan huruf kapital dan angka sesuai gambar.</p>
            <div class="pma-captcha-display" id="captcha_display">
              {{ captcha_svg|raw }}
            </div>
            <input type="text" name="pma_captcha" id="input_captcha" class="form-control pma-captcha-input" placeholder="KETIK CAPTCHA" autocomplete="off" maxlength="6">
            <input type="hidden" name="pma_captcha_token" id="captcha_token" value="{{ captcha_token }}">
          </div>
        </div>
      </div>

      {% if has_servers %}
        <div class="row mt-3 login-anim-field" style="--d:4">
          <label for="select_server" class="col-sm-4 col-form-label">
            <i class="fas fa-database"></i> {% trans 'Server choice:' %}
          </label>
          <div class="col-sm-8">
            <select name="server" id="select_server" class="form-select"
              {%- if is_arbitrary_server_allowed %} onchange="document.forms['login_form'].elements['pma_servername'].value = ''"{% endif %}>
              {{ server_options|raw }}
            </select>
          </div>
        </div>
      {% else %}
        <input type="hidden" name="server" value="{{ server }}">
      {% endif %}
    </div>
    <div class="card-footer login-anim-field" style="--d:5">
      <button class="btn btn-primary" type="submit" id="input_go">
        <i class="fas fa-sign-in-alt" id="btn_icon_login"></i>
        <i class="fas fa-sync-alt fa-spin" id="btn_icon_loading" style="display:none"></i>
        <span id="btn_text">{% trans 'Log in' %}</span>
      </button>
    </div>
  </div>
</form>

{{ login_footer|raw }}

{{ config_footer|raw }}

<style>
/* ===== Smooth entrance animation ===== */
@keyframes loginCardIn {
  from {
    opacity: 0;
    transform: translateY(18px) scale(0.98);
    filter: blur(2px);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }
}
@keyframes loginFieldIn {
  from {
    opacity: 0;
    transform: translateX(-12px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.login-anim-card {
  animation: loginCardIn 0.55s cubic-bezier(0.23, 1, 0.32, 1) both;
}

.login-anim-field {
  opacity: 0;
  animation: loginFieldIn 0.45s cubic-bezier(0.23, 1, 0.32, 1) both;
  animation-delay: calc(var(--d, 0) * 0.08s + 0.15s);
}

/* ===== Smooth transitions on interactions ===== */
.form-control, .form-select, .input-group-text {
  transition: border-color 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease;
}
.form-control:focus, .form-select:focus {
  border-color: #235a81;
  box-shadow: 0 0 0 0.15rem rgba(35, 90, 129, 0.15);
}

.btn-primary {
  transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
}
.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(35, 90, 129, 0.3);
}
.btn-primary:active {
  transform: translateY(0);
  box-shadow: 0 2px 4px rgba(35, 90, 129, 0.2);
}



.pma-captcha-refresh {
  transition: all 0.25s ease;
}
.pma-captcha-refresh:hover {
  transform: scale(1.03);
}

.card {
  transition: box-shadow 0.3s ease;
}
.card:hover {
  box-shadow: 2px 2px 5px #bbb, 0 4px 16px rgba(0,0,0,0.06);
}

/* ===== CAPTCHA display smooth fade ===== */
.pma-captcha-display {
  transition: opacity 0.2s ease;
}

/* ===== CAPTCHA dynamic theme styles ===== */
.pma-captcha-box {
  background: var(--captcha-bg, #eee);
  border: 1px solid var(--captcha-border, #aaa);
  border-radius: var(--captcha-radius, 0.25rem);
  padding: 12px 16px;
  margin-top: 12px;
  box-shadow: var(--captcha-shadow, 2px 2px 5px #ccc);
}
.pma-captcha-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 2px;
}
.pma-captcha-title {
  font-size: 15px;
  font-weight: bold;
  color: var(--captcha-title-color, #444);
  text-shadow: 1px 1px 2px var(--captcha-title-shadow, #fff);
}
.pma-captcha-refresh {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--captcha-btn-bg, #ddd);
  color: var(--captcha-btn-color, #444);
  border: 1px solid var(--captcha-btn-border, #aaa);
  border-radius: var(--captcha-radius, 0.25rem);
  padding: 4px 12px;
  font-size: 12px;
  cursor: pointer;
}
.pma-captcha-refresh:hover {
  background: var(--captcha-btn-hover-bg, #ccc);
  color: var(--captcha-btn-hover-color, #222);
  border-color: var(--captcha-btn-hover-border, #999);
}
.pma-captcha-desc {
  font-size: 12px;
  color: var(--captcha-desc-color, #666);
  margin: 0 0 10px 0;
}
.pma-captcha-display {
  background: var(--captcha-display-bg, #fff);
  border: 1px solid var(--captcha-display-border, #ccc);
  border-radius: var(--captcha-radius, 0.25rem);
  padding: 8px;
  text-align: center;
  margin-bottom: 10px;
  min-height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.pma-captcha-display svg {
  max-width: 100%;
  height: auto;
}
.pma-captcha-input {
  width: 100%;
  background: var(--captcha-input-bg, #fff) !important;
  border: 1px solid var(--captcha-input-border, #aaa) !important;
  border-radius: var(--captcha-radius, 0.25rem) !important;
  color: var(--captcha-input-color, #444) !important;
  font-size: 14px;
  font-family: 'Courier New', monospace;
  letter-spacing: 3px;
  padding: 8px 12px !important;
  text-align: center;
  text-transform: uppercase;
}
.pma-captcha-input::placeholder {
  color: var(--captcha-placeholder, #999);
  letter-spacing: 2px;
}
.pma-captcha-input:focus {
  border-color: var(--captcha-focus-border, #235a81) !important;
  box-shadow: 0 0 0 2px var(--captcha-focus-shadow, rgba(35, 90, 129, 0.15)) !important;
  outline: none;
}
.pma-captcha-input.error,
.pma-captcha-input.input-error {
  border-color: #dc3545 !important;
  box-shadow: 0 0 0 2px rgba(220, 53, 69, 0.15) !important;
}
.login-loading {
  opacity: 0.7;
  pointer-events: none;
}
#input_go {
  min-width: 100px;
}

.card-header i {
  margin-right: 5px;
}
.card-footer .btn i {
  margin-right: 5px;
}
</style>

{# jQuery 3.x sudah di-load oleh phpMyAdmin header #}
<script src="js/vendor/sweetalert2/sweetalert2.min.js"></script>
<script>
(function() {
  if (typeof jQuery === 'undefined') return;
  if (!document.getElementById('login_form')) return;

  /* ====== DETEKSI TEMA & SET CSS VARIABLES ====== */
  var themePath = '{{ theme_path }}';
  var themeMatch = themePath.match(/themes\/([^\/]+)/);
  var themeName = themeMatch ? themeMatch[1] : 'pmahomme';
  var root = document.documentElement;

  var themes = {
    pmahomme: {
      '--captcha-bg':              '#eee',
      '--captcha-border':          '#aaa',
      '--captcha-radius':          '0.25rem',
      '--captcha-shadow':          '2px 2px 5px #ccc',
      '--captcha-title-color':     '#444',
      '--captcha-title-shadow':    '#fff',
      '--captcha-desc-color':      '#666',
      '--captcha-btn-bg':          '#ddd',
      '--captcha-btn-color':       '#444',
      '--captcha-btn-border':      '#aaa',
      '--captcha-btn-hover-bg':    '#ccc',
      '--captcha-btn-hover-color': '#222',
      '--captcha-btn-hover-border':'#999',
      '--captcha-display-bg':      '#fff',
      '--captcha-display-border':  '#ccc',
      '--captcha-input-bg':        '#fff',
      '--captcha-input-border':    '#aaa',
      '--captcha-input-color':     '#444',
      '--captcha-placeholder':     '#999',
      '--captcha-focus-border':    '#235a81',
      '--captcha-focus-shadow':    'rgba(35, 90, 129, 0.15)'
    },
    original: {
      '--captcha-bg':              '#e5e5e5',
      '--captcha-border':          '#000',
      '--captcha-radius':          '0',
      '--captcha-shadow':          'none',
      '--captcha-title-color':     '#000',
      '--captcha-title-shadow':    'transparent',
      '--captcha-desc-color':      '#555',
      '--captcha-btn-bg':          '#d0dce0',
      '--captcha-btn-color':       '#000',
      '--captcha-btn-border':      '#000',
      '--captcha-btn-hover-bg':    '#8b9aa0',
      '--captcha-btn-hover-color': '#fff',
      '--captcha-btn-hover-border':'#000',
      '--captcha-display-bg':      '#f5f5f5',
      '--captcha-display-border':  '#000',
      '--captcha-input-bg':        '#f5f5f5',
      '--captcha-input-border':    '#000',
      '--captcha-input-color':     '#000',
      '--captcha-placeholder':     '#666',
      '--captcha-focus-border':    '#00f',
      '--captcha-focus-shadow':    'rgba(0, 0, 255, 0.15)'
    },
    metro: {
      '--captcha-bg':              '#f7f7f7',
      '--captcha-border':          'transparent',
      '--captcha-radius':          '0',
      '--captcha-shadow':          'none',
      '--captcha-title-color':     '#333',
      '--captcha-title-shadow':    'transparent',
      '--captcha-desc-color':      '#666',
      '--captcha-btn-bg':          '#aaa',
      '--captcha-btn-color':       '#fff',
      '--captcha-btn-border':      'transparent',
      '--captcha-btn-hover-bg':    '#888',
      '--captcha-btn-hover-color': '#fff',
      '--captcha-btn-hover-border':'transparent',
      '--captcha-display-bg':      '#fff',
      '--captcha-display-border':  '#ddd',
      '--captcha-input-bg':        '#fff',
      '--captcha-input-border':    '#ddd',
      '--captcha-input-color':     '#333',
      '--captcha-placeholder':     '#999',
      '--captcha-focus-border':    '#377796',
      '--captcha-focus-shadow':    'rgba(55, 119, 150, 0.15)'
    },
    bootstrap: {
      '--captcha-bg':              '#f8f9fa',
      '--captcha-border':          '#dee2e6',
      '--captcha-radius':          '0.375rem',
      '--captcha-shadow':          '0 0.125rem 0.25rem rgba(0,0,0,0.075)',
      '--captcha-title-color':     '#212529',
      '--captcha-title-shadow':    'transparent',
      '--captcha-desc-color':      '#6c757d',
      '--captcha-btn-bg':          '#e9ecef',
      '--captcha-btn-color':       '#212529',
      '--captcha-btn-border':      '#dee2e6',
      '--captcha-btn-hover-bg':    '#dee2e6',
      '--captcha-btn-hover-color': '#212529',
      '--captcha-btn-hover-border':'#ced4da',
      '--captcha-display-bg':      '#fff',
      '--captcha-display-border':  '#dee2e6',
      '--captcha-input-bg':        '#fff',
      '--captcha-input-border':    '#ced4da',
      '--captcha-input-color':     '#212529',
      '--captcha-placeholder':     '#6c757d',
      '--captcha-focus-border':    '#86b7fe',
      '--captcha-focus-shadow':    'rgba(13, 109, 250, 0.25)'
    }
  };

  var vars = themes[themeName] || themes.pmahomme;
  Object.keys(vars).forEach(function(key) {
    root.style.setProperty(key, vars[key]);
  });
  console.log('[LOGIN] Theme detected:', themeName);

  jQuery(function($) {
  'use strict';
  console.log('[LOGIN] jQuery version:', $.fn.jquery);

  /* ====== CAPTCHA REFRESH via jQuery AJAX ====== */
  $('#btn_refresh_captcha').on('click', function() {
    var $btn = $(this);
    var $display = $('#captcha_display');
    var $captchaInput = $('#input_captcha');

    /* spin animation via FontAwesome */
    $btn.find('i').addClass('fa-spin').prop('disabled', true);

    $.ajax({
      url: 'captcha-refresh.php',
      type: 'GET',
      dataType: 'json',
      success: function(data) {
        if (data && data.success && data.svg) {
          /* Validasi SVG sebelum inject */
          var svgStr = data.svg;
          var hasScript  = /<script[\s>]/i.test(svgStr);
          var hasEvent   = /\bon\w+\s*=/i.test(svgStr);
          var hasForeign = /<foreignobject/i.test(svgStr);
          if (!hasScript && !hasEvent && !hasForeign) {
            $display.html(svgStr);
          } else {
            Swal.fire({
              icon: 'error',
              title: 'Gagal Memperbarui CAPTCHA',
              text: 'CAPTCHA tidak valid. Silakan coba lagi.',
              timer: 5000,
              timerProgressBar: true,
              confirmButtonText: 'OK'
            });
          }
          /* Update token */
          if (data.token) {
            $('#captcha_token').val(data.token);
          }
        } else {
          Swal.fire({
            icon: 'error',
            title: 'Gagal Memperbarui CAPTCHA',
            text: 'Respons tidak valid dari server.',
            timer: 5000,
            timerProgressBar: true,
            confirmButtonText: 'OK'
          });
        }
      },
      error: function() {
        Swal.fire({
          icon: 'error',
          title: 'Kesalahan Jaringan',
          text: 'Tidak dapat memperbarui CAPTCHA. Periksa koneksi Anda.',
          timer: 5000,
          timerProgressBar: true,
          confirmButtonText: 'OK'
        });
      },
      complete: function() {
        $btn.find('i').removeClass('fa-spin').prop('disabled', false);
        $captchaInput.val('').focus();
        /* Bersihkan error phpMyAdmin */
        $('#pma_errors').remove();
        $('div[role="alert"]').remove();
      }
    });
  });

  /* ====== LOGIN FORM via jQuery Validate + jQuery AJAX ====== */
  var $loginForm = $('#login_form');

  if ($loginForm.length) {
    $loginForm.validate({
      rules: {
        pma_username:     { required: true },
        pma_password:     { required: false },
        pma_captcha:      { required: true, minlength: 6, maxlength: 6 },
        pma_captcha_token:{ required: true }
      },
      messages: {
        pma_username: { required: 'Username harus diisi.' },
        pma_captcha: {
          required:  'CAPTCHA harus diisi.',
          minlength: 'CAPTCHA harus tepat 6 karakter.',
          maxlength: 'CAPTCHA harus tepat 6 karakter.'
        },
        pma_captcha_token: { required: 'Token tidak valid.' }
      },
      errorClass: 'input-error',
      errorPlacement: function(error, $element) {
        if ($element.attr('name') === 'pma_captcha') {
          error.insertAfter('.pma-captcha-box');
        } else {
          error.insertAfter($element);
        }
      },
      submitHandler: function(form) {
        var $form     = $(form);

        console.log('[LOGIN] submitHandler fired');
        /* Tampilkan icon loading, sembunyikan icon login */
        $('#btn_icon_login').hide();
        $('#btn_icon_loading').show();
        $('#btn_text').text('Memproses...');
        $form.addClass('login-loading');

        var postData = $form.serialize() + '&ajax_request=true';
        console.log('[LOGIN] posting data length:', postData.length);

        $.ajax({
          url:      'index.php?route=/',
          type:     'POST',
          data:     postData,
          dataType: 'text',
          success: function(raw) {
            console.log('[LOGIN] AJAX success, response length:', raw ? raw.length : 0);
            console.log('[LOGIN] first 500 chars:', raw ? raw.substring(0, 500) : 'empty');
            /* Kembalikan icon button */
            $('#btn_icon_login').show();
            $('#btn_icon_loading').hide();
            $('#btn_text').text('{% trans "Log in" %}');
            $form.removeClass('login-loading');

            /* Coba parse JSON dari response */
            var data = null;
            try {
              /* Response mungkin JSON atau JSON wrapped di HTML */
              var jsonStr = raw;
              var jsonStart = raw.indexOf('{');
              var jsonEnd = raw.lastIndexOf('}');
              if (jsonStart !== -1 && jsonEnd > jsonStart) {
                jsonStr = raw.substring(jsonStart, jsonEnd + 1);
              }
              data = JSON.parse(jsonStr);
            } catch(e) {
              data = null;
            }

            if (data && data.success) {
              /* Login berhasil - tampilkan SweetAlert2 toast lalu redirect */
              Swal.fire({
                icon: 'success',
                title: 'Login Berhasil!',
                text: 'Anda akan diarahkan ke halaman utama.',
                timer: 3000,
                timerProgressBar: true,
                confirmButtonText: 'OK',
                willClose: function() {
                  window.location = 'index.php';
                }
              });
              return;
            }

            /* Ambil pesan error dari berbagai kemungkinan field */
            var msg = 'Username atau password salah.';
            if (data) {
              if (data.error) {
                msg = data.error;
              } else if (data.errSubmitMsg) {
                msg = data.errSubmitMsg;
              } else if (data.message) {
                /* response dari ResponseRenderer ajaxResponse */
                var tmp = document.createElement('div');
                tmp.innerHTML = data.message;
                msg = tmp.textContent || tmp.innerText || msg;
              }
            }
            /* Tampilkan error menggunakan SweetAlert2 */
            Swal.fire({
              icon: 'error',
              title: 'Login Gagal',
              text: msg,
              timer: 5000,
              timerProgressBar: true,
              confirmButtonText: 'OK'
            }).then(function() {
              window.location.reload();
            });
          },
          error: function(xhr, status, err) {
            console.log('[LOGIN] AJAX error:', status, err, 'status:', xhr.status);
            /* Kembalikan icon button */
            $('#btn_icon_login').show();
            $('#btn_icon_loading').hide();
            $('#btn_text').text('{% trans "Log in" %}');
            $form.removeClass('login-loading');
            var msg = 'Terjadi kesalahan jaringan. Status: ' + xhr.status;
            /* Tampilkan error menggunakan SweetAlert2 */
            Swal.fire({
              icon: 'error',
              title: 'Kesalahan Jaringan',
              text: msg,
              timer: 5000,
              timerProgressBar: true,
              confirmButtonText: 'OK'
            }).then(function() {
              window.location.reload();
            });
          }
        });
        return false;
      }
    });
  }
  });
})();
</script>
